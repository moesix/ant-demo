# .env.example - Example environment file for local development
# Copy this file to .env and update with your own values

# Application Configuration
APP_VERSION=3

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=antdemo
DB_USER=antuser
DB_PASSWORD=antpassword

# PostgreSQL Configuration
POSTGRES_USER=antuser
POSTGRES_PASSWORD=antpassword
POSTGRES_DB=antdemo

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=False

# Connection Pool Settings (for Flask-SQLAlchemy)
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_TIMEOUT=30
SQLALCHEMY_POOL_RECYCLE=1800